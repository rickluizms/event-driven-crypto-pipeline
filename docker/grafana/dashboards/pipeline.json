{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Ticks Ingested / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(pipeline_ticks_produced_total[1m])) by (symbol)",
          "legendFormat": "{{symbol}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "scheme" },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "title": "WebSocket Connection",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "pipeline_ws_connection_active", "legendFormat": "WS", "datasource": "Prometheus" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Disconnected", "color": "red" }, "1": { "text": "Connected", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "title": "Active Components",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "pipeline_active_components", "legendFormat": "Components", "datasource": "Prometheus" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 4 }, { "color": "green", "value": 8 }] }
        },
        "overrides": []
      }
    },
    {
      "title": "Candles Emitted / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(pipeline_candles_emitted_total[1m])) by (symbol, interval)",
          "legendFormat": "{{symbol}} ({{interval}})",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "title": "Indicators Emitted / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(pipeline_indicators_emitted_total[1m])) by (symbol, interval)",
          "legendFormat": "{{symbol}} ({{interval}})",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "title": "Records Persisted / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(pipeline_records_persisted_total[1m])) by (table)",
          "legendFormat": "{{table}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "title": "Cache Writes / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(pipeline_cache_writes_total[1m])) by (symbol)",
          "legendFormat": "{{symbol}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "title": "Message Processing Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_message_processing_duration_seconds_bucket[1m])) by (le, component))",
          "legendFormat": "{{component}} p95",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "title": "Batch Flush Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_batch_flush_duration_seconds_bucket[1m])) by (le, table))",
          "legendFormat": "{{table}} p95",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["crypto", "pipeline"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
